# Airtable destination for form submissions
# Personal access token: https://airtable.com/create/tokens
# Scopes required: data.records:read, data.records:write
AIRTABLE_API_KEY=pat_replace_me

# Base ID — from the base URL, e.g. https://airtable.com/appXXXXXXXX/...
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX

# Table name (the human-readable name in Airtable, NOT the table id)
# Default after CSV import is "airtable-schema" — rename to "Submissions" or update this.
AIRTABLE_TABLE_NAME=Submissions
